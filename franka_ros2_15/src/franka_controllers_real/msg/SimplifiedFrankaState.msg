# 简化版 Franka 机器人状态消息
# 用途：为了让仿真环境与 SERL 强化学习训练环境保持兼容
# 作用：以统一格式提供机器人核心状态数据，供 franka_server_ros2.py 训练接口使用
std_msgs/Header  header  # 消息头（包含时间戳、坐标系ID等标准信息）

# 末端执行器位姿：使用 4x4 齐次变换矩阵表示，采用**列优先**存储顺序
# 矩阵格式（列优先顺序展开为16个浮点数）：
# [ R11, R21, R31, 0,    第一列（旋转x轴）
#   R12, R22, R32, 0,    第二列（旋转y轴）
#   R13, R23, R33, 0,    第三列（旋转z轴）
#   tx,  ty,  tz,  1 ]   第四列（x/y/z平移量）
float64[16]  o_t_ee      # 基坐标系 -> 末端执行器 坐标系的4x4齐次变换矩阵

# 关节位置（7自由度）
# Franka 机械臂一共有7个旋转关节，依次存储7个关节的角度值（单位：弧度 rad）
float64[7]   q           # 7个关节的位置（角度）

# 关节速度（7自由度）
# 对应7个关节的实时运动速度（单位：弧度/秒 rad/s）
float64[7]   dq          # 7个关节的速度

# 刚度坐标系下的外部力/力矩信息
# 数组顺序：[沿x轴力, 沿y轴力, 沿z轴力, 绕x轴力矩, 绕y轴力矩, 绕z轴力矩]
# 注意：在仿真环境中，该值通常为0，因为仿真一般不会模拟外部接触力
float64[6]   k_f_ext_hat_k  # 末端受到的外部力和力矩（6维：3力+3矩）